<component>
  <api>
    <prop name="label" type="string" default="Metric"/>
    <prop name="value" type="string" default="--"/>
    <prop name="unit" type="string" default=""/>
    <prop name="accent" type="color" default="#color_green"/>
  </api>
  <view extends="lv_obj" width="220" height="148" flex_flow="column" flex_align_main="space_between" style_bg_color="#color_panel" style_radius="#radius" style_border_color="#color_line" style_border_width="1" style_pad_all="16">
    <lv_label text="$label" style_text_color="#color_muted" style_text_font="montserrat_16"/>
    <lv_obj width="100%" height="58" flex_flow="row" flex_align_main="start" flex_align_cross="end" style_bg_opa="0" style_pad_column="6">
      <lv_label text="$value" style_text_color="#color_text" style_text_font="montserrat_42"/>
      <lv_label text="$unit" style_text_color="#color_muted" style_text_font="montserrat_18"/>
    </lv_obj>
    <lv_obj width="100%" height="5" style_bg_color="$accent" style_radius="3"/>
  </view>
</component>
